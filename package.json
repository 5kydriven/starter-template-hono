{
	"name": "starter-template-hono",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "wrangler deploy --minify",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"docker:up": "docker compose up -d",
		"docker:down": "docker-compose down",
		"docker:clean": "docker-compose down -v",
		"docker:seed": "docker exec -i starter-template-hono-db-1 psql -U postgres -d mydb < ./src/db/seeds/create_admin.sql",
		"db:generate": "bun drizzle-kit generate",
		"db:migrate": "bun drizzle-kit migrate",
		"db:studio": "bun drizzle-kit studio",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@better-auth/drizzle-adapter": "^1.6.9",
		"@hono/zod-openapi": "^1.3.0",
		"@neondatabase/serverless": "^1.1.0",
		"@scalar/hono-api-reference": "^0.10.14",
		"better-auth": "^1.6.9",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.16",
		"pg": "^8.20.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.21",
		"@cloudflare/workers-types": "^4.20260504.1",
		"@types/node": "^25.6.0",
		"@types/pg": "^8.20.0",
		"drizzle-kit": "^0.31.10",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"wrangler": "^4.4.0"
	}
}
